root = true

[*]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true
charset = utf-8
end_of_line = lf

[*.json]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2
max_line_length = 80

[*.toml]
max_line_length = 80

[*.yaml]
indent_size = 2

[*.sh]
indent_size = 2
indent_style = space

[{*ci.yml,ci/*.yml}]
indent_size = 4

[{CMakeLists.txt,*.cmake}]
indent_size = 2
indent_style = space

[*.{c,h}]
indent_size = 4
indent_style = space
